<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PracticaGymTracker.App"
             xmlns:local="using:PracticaGymTracker"
             RequestedThemeVariant="Default">

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://Avalonia.Controls.DataGrid/Themes/Fluent.xaml"/>
        <Style Selector="DataGridRow:selected /template/ Rectangle#BackgroundRectangle">
            <Setter Property="Fill" Value="GhostWhite" />
            <Setter Property="Opacity" Value="0.1"/>
        </Style>
        <Style Selector="DataGridCell:current /template/ Grid#FocusVisual">
            <Setter Property="IsVisible" Value="False" />
        </Style>
        <Style Selector="DataGridRow:pointerover /template/ Rectangle#BackgroundRectangle">
            <Setter Property="Fill" Value="GhostWhite" />
            <Setter Property="Opacity" Value="0.1"/>
        </Style>
        <Style Selector="Border.StatCard">
            <Setter Property="Background" Value="Coral" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="15" />
            <Setter Property="Margin" Value="5" />
            <Setter Property="BoxShadow" Value="0 4 10 0 #40000000" />
        </Style>
        <Style Selector="TextBlock.StatValue">
            <Setter Property="Foreground" Value="Black" />
            <Setter Property="FontSize" Value="24" />
            <Setter Property="FontWeight" Value="Black" />
        </Style>
        <Style Selector="TextBlock.StatLabel">
            <Setter Property="Foreground" Value="Black" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="Medium" />
        </Style>
    </Application.Styles>

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://GymTrackerApp/Resources/Strings.ua.axaml" />
            </ResourceDictionary.MergedDictionaries>

            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="BgBeige">#2A2A2A</SolidColorBrush>
                    <SolidColorBrush x:Key="BgDark">#121212</SolidColorBrush>
                    <SolidColorBrush x:Key="BgCard">#1E1E1E</SolidColorBrush>
                    <SolidColorBrush x:Key="TextWhite">#FFFFFF</SolidColorBrush>
                    <SolidColorBrush x:Key="TextMuted">#888888</SolidColorBrush>
                    <SolidColorBrush x:Key="AccentMain">#FF4500</SolidColorBrush>
                </ResourceDictionary>

                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="BgBeige">#C8AD7F</SolidColorBrush>
                    <SolidColorBrush x:Key="BgDark">#F5F5F5</SolidColorBrush>      
                    <SolidColorBrush x:Key="BgCard">#FFFFFF</SolidColorBrush>      
                    <SolidColorBrush x:Key="TextWhite">#121212</SolidColorBrush>   
                    <SolidColorBrush x:Key="TextMuted">#666666</SolidColorBrush>
                    <SolidColorBrush x:Key="AccentMain">#D84315</SolidColorBrush>  
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

        </ResourceDictionary>

    </Application.Resources>

</Application>